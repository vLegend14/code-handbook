---
interface Props { title: string }
const { title } = Astro.props;
import 'xterm/css/xterm.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Apuntes interactivos de programación" />

    <!-- Fira Code para la terminal -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; background: #0f0f13; color: #e2e2e8; }
      /* Scrollbar global */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #2a2a38; border-radius: 2px; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
